  "keyFeatures": [
    "TOON format: 40-66% fewer tokens than JSON for LLM context",
    "Embedded ACID database with MVCC and WAL durability",
    "Built-in HNSW vector search with hybrid (vector + BM25) retrieval",
    "Graph overlay for agent memory with BFS/DFS traversal",
    "Context query builder with automatic token budgeting",
    "Multi-language SDKs: Python, Node.js, Go, Rust",
    "Namespace isolation for multi-tenant applications",
    "MCP (Model Context Protocol) server for Claude integration",
    "Docker deployment with gRPC server support",
    "Columnar storage with 80% I/O reduction"
  ],
  "publicApiSurface": [
    "Database.open() - Open database connection",
    "Database.put() - Store key-value pairs",
    "Database.get() - Retrieve values",
    "Database.transaction() - ACID transactions",
    "VectorIndex - HNSW vector search",
    "VectorIndex.add() - Insert vectors",
    "VectorIndex.search() - Similarity search",
    "VectorIndex.hybrid_search() - Vector + keyword fusion",
    "GraphOverlay - Agent memory graph",
    "GraphOverlay.add_node() - Create graph nodes",
    "GraphOverlay.add_edge() - Link nodes",
    "GraphOverlay.bfs() - Breadth-first traversal",
    "ContextQuery - Token-aware retrieval",
    "ContextQuery.with_token_budget() - Set token limits",
    "namespace() - Multi-tenant isolation",
    "create_collection() - Vector collections",
    "SQL queries - SELECT/INSERT/UPDATE/DELETE"
  ]
}
